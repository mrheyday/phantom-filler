# Phantom Filler Environment Variables
# Copy to .env and adjust values

# Database
PHANTOM_DATABASE_URL=postgres://phantom:phantom@localhost:5432/phantom_filler

# Redis
PHANTOM_REDIS_URL=redis://localhost:6379

# API
PHANTOM_API_HOST=127.0.0.1
PHANTOM_API_PORT=8080

# Logging
PHANTOM_LOG_LEVEL=info

# Execution (set your private key here — NEVER commit this file)
# PHANTOM_PRIVATE_KEY=
